pkgname=dnsspider
pkgver=1.5
pkgrel=1
groups=('blackarch' 'blackarch-recon' 'blackarch-scanner')
pkgdesc='A fast multithreaded bruteforcer of subdomains that leverages a wordlist and/or character permutation.'
url='http://nullsecurity.net/tools/scanner.html'
arch=('any')
license=('MIT')
depends=('python' 'python-dnspython')
source=("https://github.com/nullsecuritynet/tools/raw/main/scanner/dnsspider/release/$pkgname-$pkgver.tar.gz")
sha512sums=('46cef99c8b8bcd54912bef6277e423416673b2835433afa93a36e0af7609cddc4a3a3df9addc3f55bdea04b56c3c489335911341148a33ed70bdc05893eb8cf8')

package() {
  cd "$pkgname-$pkgver"

  install -Dm 755 "$pkgname.py" "$pkgdir/usr/bin/$pkgname"
  install -Dm 644 -t "$pkgdir/usr/share/doc/$pkgname/" README.md
}

